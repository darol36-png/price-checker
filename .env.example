# Supabase project URL (used for local Vite proxy target)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Jina Reader API key for higher rate limits (https://jina.ai/reader/)
VITE_JINA_API_KEY=your-jina-api-key

# --- Deploy na here.now (lokalnie: npm run deploy:ci) ---
# HERENOW_API_KEY=your-herenow-api-key
# HERENOW_SLUG=onyx-nebula-z9zp

# --- Test integracyjny RLS (npm run test:integration) ---
# Dwa konta testowe utworzone w Supabase Auth (email+hasło, bez wymogu potwierdzenia).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# TEST_USER_A_EMAIL=rls-test-a@example.com
# TEST_USER_A_PASSWORD=secure-password-a
# TEST_USER_B_EMAIL=rls-test-b@example.com
# TEST_USER_B_PASSWORD=secure-password-b

# --- Smoke test produkcji (npm run test:smoke) ---
# PLAYWRIGHT_BASE_URL=https://onyx-nebula-z9zp.here.now
