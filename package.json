{
  "name": "price-checker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix site",
    "build": "npm run build --prefix site",
    "lint": "npm run lint --prefix site",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "preview": "npm run preview --prefix site",
    "deploy": "bash scripts/deploy.sh",
    "deploy:ci": "bash scripts/ci-deploy.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@supabase/supabase-js": "^2.110.0",
    "vitest": "^3.2.4"
  }
}
